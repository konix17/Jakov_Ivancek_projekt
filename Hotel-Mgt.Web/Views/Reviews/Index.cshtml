@model IEnumerable<Review>

@{
    ViewData["Title"] = "Reviews";
    ViewData["Description"] = "Guest feedback and hotel ratings.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Reviews</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Guest reviews</h2>
        <div class="action-toolbar">
            <form class="ajax-search-form" asp-action="Search" asp-controller="Reviews" data-target="#reviews-results">
                <input type="search" name="q" value="@(ViewData["SearchTerm"] ?? string.Empty)" class="form-control search-input" placeholder="Search reviews..." />
            </form>
            <a class="btn btn-primary" asp-controller="Reviews" asp-action="Create">New Review</a>
        </div>
    </div>
    <div id="reviews-results">
        @await Html.PartialAsync("_ReviewsTable", Model)
    </div>
</div>
