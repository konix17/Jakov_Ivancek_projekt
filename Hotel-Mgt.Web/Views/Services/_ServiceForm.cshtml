@model ServiceFormModel

<div class="form-grid">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="form-group full-span">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="form-group form-check">
        <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
        <label asp-for="IsAvailable"></label>
        <span asp-validation-for="IsAvailable" class="text-danger"></span>
    </div>
    <div class="form-group autocomplete-block full-span">
        @await Html.PartialAsync("~/Views/Shared/_AutocompleteDropdown.cshtml", new AutocompleteDropdownModel
        {
            Label = "Hotel",
            InputId = "hotel-selection",
            InputName = "HotelSearch",
            HiddenName = "HotelId",
            SearchUrl = Url.Action("Autocomplete", "Hotels") ?? string.Empty,
            SelectedId = Model.HotelId,
            SelectedText = $"{ViewBag.SelectedHotelName}",
            Placeholder = "Search hotels..."
        })
    </div>
</div>
