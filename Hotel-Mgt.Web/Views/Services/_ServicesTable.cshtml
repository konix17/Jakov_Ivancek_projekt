@model IEnumerable<Service>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<HotelMgt.Model.Entities.AppUser> SignInManager

@{
    var isAdmin = SignInManager.IsSignedIn(User) && User.IsInRole("Admin");
}

<table class="data-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Hotel</th>
            <th>Price</th>
            <th>Available</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var service in Model)
        {
            <tr>
                <td>@service.Name</td>
                <td>@service.Hotel?.Name</td>
                <td>@service.Price€</td>
                <td><span class="badge @(service.IsAvailable ? "badge-success" : "badge-danger")">@(service.IsAvailable ? "Available" : "Unavailable")</span></td>
                <td>
                    <div class="action-buttons">
                        <a class="btn btn-secondary" asp-controller="Services" asp-action="Details" asp-route-id="@service.Id">Details</a>
                        @if (isAdmin)
                        {
                            <a class="btn btn-primary" asp-controller="Services" asp-action="Edit" asp-route-id="@service.Id">Edit</a>
                            <a class="btn btn-danger" asp-controller="Services" asp-action="Delete" asp-route-id="@service.Id">Delete</a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
