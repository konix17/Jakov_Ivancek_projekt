@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel Manager</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Flatpickr date/time picker -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hotel-Mgt.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="brand-panel">
                <a class="brand-title" asp-area="" asp-controller="Home" asp-action="Index">Hotel Manager</a>
                <p class="brand-tagline">Hotel managment system</p>
            </div>
            <nav class="sidebar-nav">
                <span class="nav-label">Main</span>
                <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                <span class="nav-label">Resources</span>
                <a class="nav-link @(currentController == "Hotels" ? "active" : "")" asp-area="" asp-controller="Hotels" asp-action="Index">Hotels</a>
                <a class="nav-link @(currentController == "Rooms" ? "active" : "")" asp-area="" asp-controller="Rooms" asp-action="Index">Rooms</a>
                <a class="nav-link @(currentController == "Guests" ? "active" : "")" asp-area="" asp-controller="Guests" asp-action="Index">Guests</a>
                <a class="nav-link @(currentController == "Reservations" ? "active" : "")" asp-area="" asp-controller="Reservations" asp-action="Index">Reservations</a>
                <a class="nav-link @(currentController == "Services" ? "active" : "")" asp-area="" asp-controller="Services" asp-action="Index">Services</a>
                <a class="nav-link @(currentController == "Employees" ? "active" : "")" asp-area="" asp-controller="Employees" asp-action="Index">Employees</a>
                <a class="nav-link @(currentController == "Payments" ? "active" : "")" asp-area="" asp-controller="Payments" asp-action="Index">Payments</a>
                <a class="nav-link @(currentController == "Reviews" ? "active" : "")" asp-area="" asp-controller="Reviews" asp-action="Index">Reviews</a>
            </nav>
            <div class="sidebar-footer">
                <p>Global view</p>
                <small>Use the sidebar to review inventory and bookings.</small>
            </div>
        </aside>

        <div class="app-main">
            <header class="page-topbar">
                <div class="page-title">
                    <span class="page-micro">Hotel management</span>
                    <h1>@ViewData["Title"]</h1>
                    @if (ViewData["Description"] != null)
                    {
                        <p class="page-note">@ViewData["Description"]</p>
                    }
                </div>
                <div class="breadcrumb-shell">
                    @RenderSection("Breadcrumbs", required: false)
                </div>
            </header>

            <main class="page-content" role="main">
                @RenderBody()
            </main>

            <footer class="app-footer">
                <span>&copy; 2026 Hotel Manager</span>
                <span>Powered by Jakov Ivanček</span>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Flatpickr date/time picker -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <!-- Flatpickr localization -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/hr.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
