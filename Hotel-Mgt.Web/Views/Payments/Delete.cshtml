@model Payment

@{
    ViewData["Title"] = "Delete Payment";
    ViewData["Description"] = "Confirm payment deletion.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <a asp-controller="Payments" asp-action="Index">Payments</a>
        <span class="sep">/</span>
        <span class="current">Delete</span>
    </nav>
}

<div class="panel-card">
    <h2>Delete Payment</h2>
    <p>Are you sure you want to delete the payment of <strong>@Model.Amount.ToString("C")</strong>?</p>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
