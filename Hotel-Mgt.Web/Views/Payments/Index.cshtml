@model IEnumerable<Payment>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<HotelMgt.Model.Entities.AppUser> SignInManager

@{
    var isAdmin = SignInManager.IsSignedIn(User) && User.IsInRole("Admin");
    ViewData["Title"] = "Payments";
    ViewData["Description"] = "Payment transactions and settlement status.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Payments</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Payment records</h2>
        <div class="action-toolbar">
            <form class="ajax-search-form" asp-action="Search" asp-controller="Payments" data-target="#payments-results">
                <input type="search" name="q" value="@(ViewData["SearchTerm"] ?? string.Empty)" class="form-control search-input" placeholder="Search payments..." />
            </form>
            @if (isAdmin)
            {
                <a class="btn btn-primary" asp-controller="Payments" asp-action="Create">New Payment</a>
            }
        </div>
    </div>
    <div id="payments-results">
        @await Html.PartialAsync("_PaymentsTable", Model)
    </div>
</div>
