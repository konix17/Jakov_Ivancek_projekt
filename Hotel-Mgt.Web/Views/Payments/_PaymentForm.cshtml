@model PaymentFormModel

<div class="form-grid">
    <div class="form-group">
        <label asp-for="Amount"></label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    @if (Model.Id != 0)
    {
        <div class="form-group">
            @await Html.PartialAsync("~/Views/Shared/_DateTimePicker.cshtml", new DateTimePickerModel
            {
                Label = "Payment date",
                InputId = "payment-date",
                Name = "PaymentDate",
                Value = Model.PaymentDate,
                Placeholder = "dd.MM.yyyy."
            })
        </div>
    }
    <div class="form-group">
        <label asp-for="PaymentMethod"></label>
        <select asp-for="PaymentMethod" asp-items="Html.GetEnumSelectList<PaymentMethod>()" class="form-control"></select>
        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
    </div>
    <div class="form-group form-check">
        <input asp-for="IsPaid" class="form-check-input" type="checkbox" />
        <label asp-for="IsPaid" class="form-check-label"></label>
        <span asp-validation-for="IsPaid" class="text-danger"></span>
    </div>
    <div class="form-group autocomplete-block">
        @await Html.PartialAsync("~/Views/Shared/_AutocompleteDropdown.cshtml", new AutocompleteDropdownModel
        {
            Label = "Reservation",
            InputId = "reservation-selection",
            InputName = "ReservationSearch",
            HiddenName = "ReservationId",
            SearchUrl = Url.Action("Autocomplete", "Reservations") ?? string.Empty,
            SelectedId = Model.ReservationId,
            SelectedText = $"{ViewBag.SelectedReservationCode}",
            Placeholder = "Search reservations..."
        })
    </div>
</div>
