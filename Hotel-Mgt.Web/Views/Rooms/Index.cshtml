@model IEnumerable<Room>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<HotelMgt.Model.Entities.AppUser> SignInManager

@{
    var isAdmin = SignInManager.IsSignedIn(User) && User.IsInRole("Admin");
    ViewData["Title"] = "Rooms";
    ViewData["Description"] = "Room inventory, availability and current hotel assignments.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Rooms</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Room listings</h2>
        <div class="action-toolbar">
            <form class="ajax-search-form" asp-action="Search" asp-controller="Rooms" data-target="#rooms-results">
                <input type="search" name="q" value="@(ViewData["SearchTerm"] ?? string.Empty)" class="form-control search-input" placeholder="Search rooms..." />
            </form>
            @if (isAdmin)
            {
                <a class="btn btn-primary" asp-controller="Rooms" asp-action="Create">New Room</a>
            }
        </div>
    </div>
    <div id="rooms-results">
        @await Html.PartialAsync("_RoomsTable", Model)
    </div>
</div>
