@model IEnumerable<Room>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<HotelMgt.Model.Entities.AppUser> SignInManager

@{
    var isAdmin = SignInManager.IsSignedIn(User) && User.IsInRole("Admin");
}

<table class="data-table">
    <thead>
        <tr>
            <th>Number</th>
            <th>Type</th>
            <th>Floor</th>
            <th>Capacity</th>
            <th>Nightly</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Model)
        {
            <tr>
                <td>@room.RoomNumber</td>
                <td>@room.RoomType</td>
                <td>@room.Floor</td>
                <td>@room.Capacity</td>
                <td>@room.PricePerNight€</td>
                <td>
                    <span class="badge @(room.IsAvailable ? "badge-success" : "badge-danger")">@(room.IsAvailable ? "Available" : "Occupied")</span>
                </td>
                <td>
                    <div class="action-buttons">
                        <a class="btn btn-secondary" asp-controller="Rooms" asp-action="Details" asp-route-id="@room.Id">Details</a>
                        @if (isAdmin)
                        {
                            <a class="btn btn-primary" asp-controller="Rooms" asp-action="Edit" asp-route-id="@room.Id">Edit</a>
                            <a class="btn btn-danger" asp-controller="Rooms" asp-action="Delete" asp-route-id="@room.Id">Delete</a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
