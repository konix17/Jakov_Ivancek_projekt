@model HotelMgt.Web.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    ViewData["Description"] = "Create a local account to access the hotel management portal.";
}

<div class="panel-card">
    <h2>Create an account</h2>
    <p class="text-muted">This screen uses the built-in Identity registration flow and stores the extra profile field for OIB.</p>

    <form asp-action="Register" method="post" class="form-grid">
        <div asp-validation-summary="ModelOnly" class="text-danger full-span"></div>

        <div class="form-group full-span">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group full-span">
            <label asp-for="Password"></label>
            <input asp-for="Password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-group full-span">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" class="form-control" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="form-group full-span">
            <label asp-for="OIB"></label>
            <input asp-for="OIB" class="form-control" />
        </div>

        <input asp-for="ReturnUrl" type="hidden" />

        <div class="form-actions full-span">
            <button type="submit" class="btn btn-primary">Register</button>
            <a asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-secondary">Already have an account?</a>
        </div>
    </form>

    <hr class="my-4" />

    <div class="small-card">
        <h3>Or continue with Google</h3>
        @if (ViewData["GoogleEnabled"] is true)
        {
            <p class="text-muted">You can also create or sign in with your Google account.</p>
            <div class="action-buttons">
                <a class="btn btn-light border d-inline-flex align-items-center gap-2" asp-action="ExternalLogin" asp-route-provider="Google" asp-route-returnUrl="@Model.ReturnUrl">
                    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" focusable="false" style="flex-shrink:0;">
                        <path fill="#4285F4" d="M21.805 10.023H12.2v3.954h5.42c-.236 1.24-.97 2.29-2.06 2.99v2.48h3.33c1.95-1.79 3.07-4.43 3.07-7.42 0-.64-.06-1.26-.16-1.85z"/>
                        <path fill="#34A853" d="M12.2 22c2.78 0 5.11-.92 6.82-2.49l-3.33-2.48c-.92.62-2.1.98-3.49.98-2.68 0-4.95-1.81-5.76-4.24H3.03v2.66C4.74 19.67 8.19 22 12.2 22z"/>
                        <path fill="#FBBC05" d="M6.44 13.77A5.83 5.83 0 0 1 6.44 10.2V7.54H3.03a9.97 9.97 0 0 0 0 6.23l3.41-2z"/>
                        <path fill="#EA4335" d="M12.2 6.03c1.51 0 2.87.52 3.94 1.53l2.95-2.95C17.31 3.06 15 2 12.2 2 8.19 2 4.74 4.33 3.03 7.54l3.41 2.66c.81-2.43 3.08-4.24 5.76-4.24z"/>
                    </svg>
                    Continue with Google
                </a>
            </div>
        }
        else
        {
            <p class="text-muted">Google sign-in is currently unavailable because the Google settings are not configured.</p>
        }
    </div>
</div>
