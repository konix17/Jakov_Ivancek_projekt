@model Guest

@{
    ViewData["Title"] = "Guest Details";
    ViewData["Description"] = Model.FirstName + " " + Model.LastName;
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <a asp-controller="Guests" asp-action="Index">Guests</a>
        <span class="sep">/</span>
        <span class="current">@Model.FirstName @Model.LastName</span>
    </nav>
}

<div class="detail-grid">
    <div class="panel-card">
        <div class="section-header">
            <h2>Profile</h2>
        </div>
        <dl class="detail-list">
            <dt>Name</dt>
            <dd>@Model.FirstName @Model.LastName</dd>
            <dt>Email</dt>
            <dd>@Model.Email</dd>
            <dt>Phone</dt>
            <dd>@Model.PhoneNumber</dd>
            <dt>Date of birth</dt>
            <dd>@Model.DateOfBirth.ToString("dd.MM.yyyy.")</dd>
            <dt>Document</dt>
            <dd>@Model.DocumentNumber</dd>
        </dl>
    </div>

    <aside class="panel-card">
        <div class="stat-block">
            <strong>@Model.Reservations.Count</strong>
            <span>Reservations</span>
        </div>
        <div class="stat-block">
            <strong>@Model.Reviews.Count</strong>
            <span>Reviews</span>
        </div>
        <a class="btn btn-secondary" asp-controller="Guests" asp-action="Index">Back to Guests</a>
    </aside>
</div>
