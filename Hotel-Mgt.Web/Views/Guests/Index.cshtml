@model IEnumerable<Guest>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<HotelMgt.Model.Entities.AppUser> SignInManager

@{
    var isAdmin = SignInManager.IsSignedIn(User) && User.IsInRole("Admin");
    ViewData["Title"] = "Guests";
    ViewData["Description"] = "Guest records, contact information and reservation history.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Guests</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Guest directory</h2>
        <div class="action-toolbar">
            <form class="ajax-search-form" asp-action="Search" asp-controller="Guests" data-target="#guests-results">
                <input type="search" name="q" value="@(ViewData["SearchTerm"] ?? string.Empty)" class="form-control search-input" placeholder="Search guests..." />
            </form>
            @if (isAdmin)
            {
                <a class="btn btn-primary" asp-controller="Guests" asp-action="Create">New Guest</a>
            }
        </div>
    </div>
    <div id="guests-results">
        @await Html.PartialAsync("_GuestsTable", Model)
    </div>
</div>
