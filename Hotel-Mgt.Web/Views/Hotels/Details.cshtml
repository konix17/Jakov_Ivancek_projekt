@model Hotel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<HotelMgt.Model.Entities.AppUser> SignInManager

@{
    var isAdmin = SignInManager.IsSignedIn(User) && User.IsInRole("Admin");
    ViewData["Title"] = "Hotel Details";
    ViewData["Description"] = Model.Name;
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <a asp-controller="Hotels" asp-action="Index">Hotels</a>
        <span class="sep">/</span>
        <span class="current">@Model.Name</span>
    </nav>
}

<div class="detail-grid">
    <div class="panel-card">
        <div class="section-header">
            <h2>Overview</h2>
        </div>
        <dl class="detail-list">
            <dt>Name</dt>
            <dd>@Model.Name</dd>
            <dt>Address</dt>
            <dd>@Model.Address</dd>
            <dt>City</dt>
            <dd>@Model.City</dd>
            <dt>Rating</dt>
            <dd>@Model.Rating / 5</dd>
            <dt>Phone</dt>
            <dd>@Model.PhoneNumber</dd>
        </dl>
    </div>

    <aside class="panel-card">
        @if (TempData["AttachmentMessage"] is string message)
        {
            <div class="alert alert-success">@message</div>
        }

        <div class="stat-block">
            <strong>@(Model.Rooms?.Count ?? 0)</strong>
            <span>Rooms</span>
        </div>
        <div class="stat-block">
            <strong>@(Model.Employees?.Count ?? 0)</strong>
            <span>Employees</span>
        </div>
        <div class="stat-block">
            <strong>@(Model.Services?.Count ?? 0)</strong>
            <span>Services</span>
        </div>
        <div class="stat-block">
            <strong>@(Model.Reservations?.Count ?? 0)</strong>
            <span>Reservations</span>
        </div>
        <a class="btn btn-secondary" asp-controller="Hotels" asp-action="Index">Back to Hotels</a>
    </aside>
</div>

<div id="attachmentAntiForgery" style="display:none;">@Html.AntiForgeryToken()</div>

<div class="panel-card">
    <div class="section-header">
        <h2>Hotel documents</h2>
        @if (isAdmin)
        {
            <form asp-action="UploadAttachment" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="d-flex gap-2 flex-wrap align-items-center">
                <input type="file" name="file" class="form-control" />
                <button type="submit" class="btn btn-primary">Upload file</button>
            </form>
        }
    </div>
    <div id="attachmentList"></div>
</div>

@section Scripts {
    <script>
        function loadAttachments() {
            fetch('@Url.Action("GetAttachments", "Hotels", new { id = Model.Id })')
                .then(r => r.text())
                .then(html => document.getElementById('attachmentList').innerHTML = html);
        }

        function deleteAttachment(id) {
            if (!confirm('Delete this file?')) return;

            const url = '/Hotels/@Model.Id/attachments/' + id + '/delete';
            const token = document.querySelector('#attachmentAntiForgery input[name="__RequestVerificationToken"]').value;

            fetch(url, {
                method: 'POST',
                credentials: 'same-origin',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': token,
                    'X-CSRF-TOKEN': token,
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: new URLSearchParams({ __RequestVerificationToken: token }).toString()
            })
                .then(async response => {
                    if (!response.ok) {
                        throw new Error('Delete request failed.');
                    }

                    await loadAttachments();
                })
                .catch(error => {
                    console.error(error);
                    alert('The file could not be deleted. Please try again.');
                });
        }

        document.addEventListener('DOMContentLoaded', loadAttachments);
    </script>
}
