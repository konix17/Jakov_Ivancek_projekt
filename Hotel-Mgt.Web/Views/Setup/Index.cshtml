@model List<HotelMgt.Web.Controllers.UserRolesViewModel>
@{
    ViewData["Title"] = "Setup";
    ViewData["Description"] = "Reset the demo data, ensure roles, or manage user permissions for Lab5.";
}

<div class="panel-card mb-4">
    <h2>Lab5 setup actions</h2>
    <p class="text-muted">These actions are available for testing and demo purposes. They help you reset the database and verify the Identity role setup.</p>

    @if (TempData["Message"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }
    @if (TempData["ErrorMessage"] is string errMessage)
    {
        <div class="alert alert-danger">@errMessage</div>
    }

    <div class="form-grid">
        <div class="small-card">
            <h3>Reset demo data</h3>
            <p class="text-muted">Deletes and recreates the SQLite database so the seeded sample rooms, hotels, and reservations are available again.</p>
            <form asp-action="ResetDatabase" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Reset database</button>
            </form>
        </div>

        <div class="small-card">
            <h3>Ensure roles exist</h3>
            <p class="text-muted">Creates the Admin and Manager roles used by the authentication and authorization checks.</p>
            <form asp-action="EnsureRoles" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">Create roles</button>
            </form>
        </div>
    </div>
</div>

<div class="panel-card">
    <h2>User Role Management</h2>
    <p class="text-muted">Manage roles for all registered users. Changes take effect on their next request.</p>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive mt-3">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Email / Username</th>
                        <th>Current Roles</th>
                        <th style="width: 300px;">Assign Role</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <strong>@user.Email</strong>
                            </td>
                            <td>
                                @if (user.Roles.Any())
                                {
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge bg-primary me-1">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No roles assigned</span>
                                }
                            </td>
                            <td>
                                <form asp-action="UpdateUserRole" method="post" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <select name="roleName" class="form-select form-select-sm">
                                        <option value="User" selected="@(user.Roles.Contains("User") ? "selected" : null)">User</option>
                                        <option value="Manager" selected="@(user.Roles.Contains("Manager") ? "selected" : null)">Manager</option>
                                        <option value="Admin" selected="@(user.Roles.Contains("Admin") ? "selected" : null)">Admin</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-secondary">Save</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No users found.</p>
    }
</div>
