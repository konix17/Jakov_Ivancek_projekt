@model EmployeeFormModel

<div class="form-grid">
    <div class="form-group">
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="LastName"></label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="PhoneNumber"></label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Salary"></label>
        <input asp-for="Salary" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Salary" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Role"></label>
        <select asp-for="Role" asp-items="Html.GetEnumSelectList<EmployeeRole>()" class="form-control"></select>
        <span asp-validation-for="Role" class="text-danger"></span>
    </div>
    <div class="form-group">
        @await Html.PartialAsync("~/Views/Shared/_DateTimePicker.cshtml", new DateTimePickerModel
        {
            Label = "Hire date",
            InputId = "hire-date",
            Name = "HireDate",
            Value = Model.HireDate,
            Placeholder = "dd.MM.yyyy."
        })
    </div>
    <div class="form-group autocomplete-block">
        @await Html.PartialAsync("~/Views/Shared/_AutocompleteDropdown.cshtml", new AutocompleteDropdownModel
        {
            Label = "Hotel",
            InputId = "hotel-selection",
            InputName = "HotelSearch",
            HiddenName = "HotelId",
            SearchUrl = Url.Action("Autocomplete", "Hotels") ?? string.Empty,
            SelectedId = Model.HotelId,
            SelectedText = $"{ViewBag.SelectedHotelName}",
            Placeholder = "Search hotels..."
        })
    </div>
</div>
