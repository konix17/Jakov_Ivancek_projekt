@model Employee

@{
    ViewData["Title"] = "Employee Details";
    ViewData["Description"] = Model.FirstName + " " + Model.LastName;
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <a asp-controller="Employees" asp-action="Index">Employees</a>
        <span class="sep">/</span>
        <span class="current">@Model.FirstName @Model.LastName</span>
    </nav>
}

<div class="detail-grid">
    <div class="panel-card">
        <div class="section-header">
            <h2>Employee profile</h2>
        </div>
        <dl class="detail-list">
            <dt>Name</dt>
            <dd>@Model.FirstName @Model.LastName</dd>
            <dt>Email</dt>
            <dd>@Model.Email</dd>
            <dt>Phone</dt>
            <dd>@Model.PhoneNumber</dd>
            <dt>Role</dt>
            <dd>@Model.Role</dd>
            <dt>Salary</dt>
            <dd>@Model.Salary€</dd>
            <dt>Hotel</dt>
            <dd>
                @if (Model.Hotel != null)
                {
                    <a asp-controller="Hotels" asp-action="Details" asp-route-id="@Model.Hotel.Id">@Model.Hotel.Name</a>
                }
                else
                {
                    @:Unassigned
                }
            </dd>
        </dl>
    </div>

    <aside class="panel-card">
        <div class="stat-block">
            <strong>Staff record</strong>
            <span>Managed by hotel operations</span>
        </div>
        <a class="btn btn-secondary" asp-controller="Employees" asp-action="Index">Back to Employees</a>
    </aside>
</div>
