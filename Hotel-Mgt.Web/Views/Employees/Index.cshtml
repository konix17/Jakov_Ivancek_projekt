@model IEnumerable<Employee>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<HotelMgt.Model.Entities.AppUser> SignInManager

@{
    var isAdmin = SignInManager.IsSignedIn(User) && User.IsInRole("Admin");
    ViewData["Title"] = "Employees";
    ViewData["Description"] = "Team members, roles and salary details.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Employees</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Employee roster</h2>
        <div class="action-toolbar">
            <form class="ajax-search-form" asp-action="Search" asp-controller="Employees" data-target="#employees-results">
                <input type="search" name="q" value="@(ViewData["SearchTerm"] ?? string.Empty)" class="form-control search-input" placeholder="Search employees..." />
            </form>
            @if (isAdmin)
            {
                <a class="btn btn-primary" asp-controller="Employees" asp-action="Create">New Employee</a>
            }
        </div>
    </div>
    <div id="employees-results">
        @await Html.PartialAsync("_EmployeesTable", Model)
    </div>
</div>
