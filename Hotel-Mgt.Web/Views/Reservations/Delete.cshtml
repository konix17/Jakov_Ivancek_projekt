@model Reservation

@{
    ViewData["Title"] = "Delete Reservation";
    ViewData["Description"] = "Confirm reservation cancellation.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <a asp-controller="Reservations" asp-action="Index">Reservations</a>
        <span class="sep">/</span>
        <span class="current">Delete</span>
    </nav>
}

<div class="panel-card">
    <h2>Delete Reservation</h2>
    <p>Are you sure you want to delete reservation for <strong>@Model.Guest?.FirstName @Model.Guest?.LastName</strong>?</p>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
