@model ReservationFormModel

@{
    ViewData["Title"] = "Edit Reservation";
    ViewData["Description"] = "Update reservation information.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <a asp-controller="Reservations" asp-action="Index">Reservations</a>
        <span class="sep">/</span>
        <span class="current">Edit</span>
    </nav>
}

<div class="panel-card">
    <h2>Edit Reservation</h2>
    <form asp-action="Edit" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        @await Html.PartialAsync("_ReservationForm", Model)
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a class="btn btn-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
