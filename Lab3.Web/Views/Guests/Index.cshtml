@model IEnumerable<Lab3.Model.Entities.Guest>

@{
    ViewData["Title"] = "Guests";
    ViewData["Description"] = "Guest records, contact information and reservation history.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Guests</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Guest directory</h2>
        <a class="btn btn-primary" asp-controller="Guests" asp-action="Index">Refresh</a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Reservations</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var guest in Model)
            {
                <tr>
                    <td>@guest.FirstName @guest.LastName</td>
                    <td>@guest.Email</td>
                    <td>@guest.PhoneNumber</td>
                    <td>@guest.Reservations.Count</td>
                    <td>
                        <a class="btn btn-secondary" asp-controller="Guests" asp-action="Details" asp-route-id="@guest.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
