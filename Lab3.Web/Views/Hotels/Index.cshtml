@model IEnumerable<Lab3.Model.Entities.Hotel>

@{
    ViewData["Title"] = "Hotels";
    ViewData["Description"] = "Hotel locations, ratings and available operations.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Hotels</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Hotel inventory</h2>
        <a class="btn btn-primary" asp-controller="Hotels" asp-action="Index">Refresh</a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>City</th>
                <th>Rating</th>
                <th>Phone</th>
                <th>Rooms</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var hotel in Model)
            {
                <tr>
                    <td>@hotel.Name</td>
                    <td>@hotel.City</td>
                    <td>@hotel.Rating</td>
                    <td>@hotel.PhoneNumber</td>
                    <td>@hotel.Rooms.Count</td>
                    <td>
                        <a class="btn btn-secondary" asp-controller="Hotels" asp-action="Details" asp-route-id="@hotel.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
