{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh .github/hooks/stop_hook.sh",
            "cwd": "."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh .github/hooks/stop_hook.sh",
            "cwd": "."
          }
        ]
      }
    ],
    "PostInvocation": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh .github/hooks/stop_hook.sh",
            "cwd": "."
          }
        ]
      }
    ]
  }
}
