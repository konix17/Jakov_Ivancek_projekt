@model IEnumerable<Lab1.Model.Entities.Service>

@{
    ViewData["Title"] = "Services";
    ViewData["Description"] = "Service offerings, pricing and hotel availability.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Services</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Service catalog</h2>
        <a class="btn btn-primary" asp-controller="Services" asp-action="Index">Refresh</a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Hotel</th>
                <th>Price</th>
                <th>Available</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var service in Model)
            {
                <tr>
                    <td>@service.Name</td>
                    <td>@service.Hotel?.Name</td>
                    <td>@service.Price€</td>
                    <td><span class="badge @(service.IsAvailable ? "badge-success" : "badge-danger")">@(service.IsAvailable ? "Available" : "Unavailable")</span></td>
                    <td>
                        <a class="btn btn-secondary" asp-controller="Services" asp-action="Details" asp-route-id="@service.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
