@model IEnumerable<Lab1.Model.Entities.Payment>

@{
    ViewData["Title"] = "Payments";
    ViewData["Description"] = "Payment transactions and settlement status.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Payments</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Payment records</h2>
        <a class="btn btn-primary" asp-controller="Payments" asp-action="Index">Refresh</a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Amount</th>
                <th>Date</th>
                <th>Method</th>
                <th>Status</th>
                <th>Reservation</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var payment in Model)
            {
                <tr>
                    <td>@payment.Amount:C</td>
                    <td>@payment.PaymentDate:g</td>
                    <td>@payment.PaymentMethod</td>
                    <td><span class="badge @(payment.IsPaid ? "badge-success" : "badge-warning")">@(payment.IsPaid ? "Paid" : "Pending")</span></td>
                    <td>@payment.Reservation?.ReservationCode</td>
                    <td>
                        <a class="btn btn-secondary" asp-controller="Payments" asp-action="Details" asp-route-id="@payment.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
