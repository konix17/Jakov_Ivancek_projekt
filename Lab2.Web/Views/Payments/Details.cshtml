@model Lab1.Model.Entities.Payment

@{
    ViewData["Title"] = "Payment Details";
    ViewData["Description"] = Model.PaymentDate.ToString("g");
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <a asp-controller="Payments" asp-action="Index">Payments</a>
        <span class="sep">/</span>
        <span class="current">Payment @Model.Id</span>
    </nav>
}

<div class="detail-grid">
    <div class="panel-card">
        <div class="section-header">
            <h2>Payment details</h2>
        </div>
        <dl class="detail-list">
            <dt>Amount</dt>
            <dd>@Model.Amount:C</dd>
            <dt>Date</dt>
            <dd>@Model.PaymentDate:g</dd>
            <dt>Method</dt>
            <dd>@Model.PaymentMethod</dd>
            <dt>Payment status</dt>
            <dd><span class="badge @(Model.IsPaid ? "badge-success" : "badge-warning")">@(Model.IsPaid ? "Paid" : "Pending")</span></dd>
            <dt>Reservation</dt>
            <dd>
                @if (Model.Reservation != null)
                {
                    <a asp-controller="Reservations" asp-action="Details" asp-route-id="@Model.Reservation.Id">@Model.Reservation.ReservationCode</a>
                }
                else
                {
                    @:None
                }
            </dd>
        </dl>
    </div>

    <aside class="panel-card">
        <div class="stat-block">
            <strong>@(Model.IsPaid ? "Settled" : "Awaiting")</strong>
            <span>Current payment status</span>
        </div>
        <a class="btn btn-secondary" asp-controller="Payments" asp-action="Index">Back to Payments</a>
    </aside>
</div>
