@model IEnumerable<Lab1.Model.Entities.Employee>

@{
    ViewData["Title"] = "Employees";
    ViewData["Description"] = "Team members, roles and salary details.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Employees</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Employee roster</h2>
        <a class="btn btn-primary" asp-controller="Employees" asp-action="Index">Refresh</a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Role</th>
                <th>Hotel</th>
                <th>Salary</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in Model)
            {
                <tr>
                    <td>@employee.FirstName @employee.LastName</td>
                    <td>@employee.Role</td>
                    <td>@employee.Hotel?.Name</td>
                    <td>@employee.Salary€</td>
                    <td>
                        <a class="btn btn-secondary" asp-controller="Employees" asp-action="Details" asp-route-id="@employee.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
