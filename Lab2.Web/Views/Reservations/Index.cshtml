@model IEnumerable<Lab1.Model.Entities.Reservation>

@{
    ViewData["Title"] = "Reservations";
    ViewData["Description"] = "Booking records, status and relation to guests and rooms.";
}

@section Breadcrumbs {
    <nav class="breadcrumb-nav">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="sep">/</span>
        <span class="current">Reservations</span>
    </nav>
}

<div class="panel-card">
    <div class="section-header">
        <h2>Reservation log</h2>
        <a class="btn btn-primary" asp-controller="Reservations" asp-action="Index">Refresh</a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Guest</th>
                <th>Room</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Status</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reservation in Model)
            {
                <tr>
                    <td>@reservation.ReservationCode</td>
                    <td>@reservation.Guest?.FirstName @reservation.Guest?.LastName</td>
                    <td>@reservation.Room?.RoomNumber</td>
                    <td>@reservation.CheckInDate:d</td>
                    <td>@reservation.CheckOutDate:d</td>
                    <td><span class="badge badge-info">@reservation.Status</span></td>
                    <td>@reservation.TotalPrice:C</td>
                    <td>
                        <a class="btn btn-secondary" asp-controller="Reservations" asp-action="Details" asp-route-id="@reservation.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
